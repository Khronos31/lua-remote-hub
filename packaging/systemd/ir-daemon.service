[Unit]
Description=USB-IR Remote Control Daemon (ir-remapper)
After=network.target

[Service]
WorkingDirectory=/usr/share/lua-remote-hub/lua
ExecStart=/usr/bin/lua /usr/share/lua-remote-hub/lua/main.lua
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
